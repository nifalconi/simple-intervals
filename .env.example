# Copy to `.env.local` (gitignored) and edit.
# Only variables prefixed with VITE_ are exposed to the client bundle.
# NEVER put secrets here — this is a static PWA; anything shipped is public.

# Base path for production builds. Set automatically by the GitHub Action
# to "/<repo>/". Override for custom domains or subdirectory hosting.
VITE_BASE=/

# Example feature flags / public config (uncomment + rename as needed).
# VITE_APP_TAGLINE="Track anything, anywhere."
# VITE_POLL_INTERVAL_MS=60000
